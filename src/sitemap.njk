---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ settings.siteUrl }}/</loc>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>{{ settings.siteUrl }}/products/</loc>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>{{ settings.siteUrl }}/search/</loc>
    <priority>0.6</priority>
  </url>
  {% for product in products %}
  {% if product.is_active != false %}
  <url>
    <loc>{{ settings.siteUrl }}/products/{{ product.slug }}/</loc>
    <priority>0.8</priority>
  </url>
  {% endif %}
  {% endfor %}
  {% for category in categories %}
  <url>
    <loc>{{ settings.siteUrl }}/categories/{{ category.slug }}/</loc>
    <priority>0.7</priority>
  </url>
  {% endfor %}
  {% for collection in featuredCollections %}
  <url>
    <loc>{{ settings.siteUrl }}/featured/{{ collection.slug }}/</loc>
    <priority>0.7</priority>
  </url>
  {% endfor %}
  {% for space in spaces %}
  <url>
    <loc>{{ settings.siteUrl }}/spaces/{{ space.slug }}/</loc>
    <priority>0.7</priority>
  </url>
  {% endfor %}
</urlset>
