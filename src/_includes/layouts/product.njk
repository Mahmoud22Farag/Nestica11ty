---
layout: layouts/base.njk
---

<section class="container my-5">
  <div class="row g-5 align-items-start">
    <div class="col-lg-6">
      <div class="product-main-wrap">
        <img
          id="mainProductImage"
          src="{{ (product.main_image or '/assets/images/products/default-product.jpeg') | url }}"
          alt="{{ product.name }}"
          class="img-fluid rounded-4 w-100 shadow-sm"
          loading="lazy"
          onerror="this.onerror=null;this.src='{{ '/assets/images/products/default-product.jpeg' | url }}';"
        >
      </div>

      {% if product.gallery and product.gallery.length %}
      <div class="product-thumbs d-flex gap-3 flex-wrap mt-3">
        {% for img in product.gallery %}
          <img
            src="{{ img | url }}"
            alt="{{ product.name }}"
            class="rounded-3 border"
            loading="lazy"
            onclick="changeMainImage('{{ img | url }}')"
            onerror="this.onerror=null;this.src='{{ '/assets/images/products/default-product.jpeg' | url }}';"
          >
        {% endfor %}
      </div>
      {% endif %}
    </div>

    <div class="col-lg-6">
      {% if product.category_name %}
      <span class="badge rounded-pill bg-warning text-dark mb-3">
        {{ product.category_name }}
      </span>
      {% endif %}

      <h1 class="fw-bold mb-3">{{ product.name }}</h1>

      <div class="product-card-price mb-4">
        <span class="main-price">{{ product.price | egp }}</span>

        {% if product.old_price %}
        <span class="old-price">{{ product.old_price | egp }}</span>
        {% endif %}
      </div>

      <div class="mb-3">
        <label class="form-label fw-bold" data-i18n="quantity">الكمية</label>
        <input
          id="quantity"
          type="number"
          min="1"
          value="1"
          class="form-control"
        >
      </div>

      <div class="mb-3">
        <label class="form-label fw-bold" data-i18n="requestType">نوع الطلب</label>

        <div class="form-check">
          <input
            class="form-check-input"
            type="radio"
            name="requestType"
            id="requestTypeSame"
            value="same"
            checked
            onchange="toggleNotes()"
          >
          <label class="form-check-label" for="requestTypeSame" data-i18n="sameAsProduct">
            نفس المنتج
          </label>
        </div>

        <div class="form-check">
          <input
            class="form-check-input"
            type="radio"
            name="requestType"
            id="requestTypeCustom"
            value="custom"
            onchange="toggleNotes()"
          >
          <label class="form-check-label" for="requestTypeCustom" data-i18n="customModification">
            تعديل خاص
          </label>
        </div>
      </div>

      <div id="notesBox" class="mb-4" style="display:none;">
        <label class="form-label fw-bold" data-i18n="writeRequest">اكتب طلبك</label>
        <textarea id="notes" class="form-control" rows="4"></textarea>
      </div>

      <button
        type="button"
        class="btn btn-warning rounded-pill px-5 py-2 fw-bold"
        data-i18n="addToCart"
        onclick='addProductDetailsToCart({
          id: "{{ product.id }}",
          name: "{{ product.name | escape }}",
          price: {{ product.price or 0 }},
          image: "{{ product.main_image or '/assets/images/products/default-product.jpeg' }}",
          slug: "{{ product.slug }}"
        })'
      >
        أضف للسلة
      </button>
    </div>
  </div>
</section>

<section class="container my-5">
  <div class="row g-4">
    <div class="col-lg-7">
      <div class="product-desc-card">
        <h3 class="desc-title" data-i18n="description">الوصف</h3>
        <hr class="desc-divider">

        <div class="desc-content">
          {{ (product.description_ar or product.description or '') | replace('\n', '<br>') | safe }}
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="product-desc-card">
        <h3 class="desc-title" data-i18n="specifications">المواصفات</h3>
        <hr class="desc-divider">

        <div class="specs-table">
          <div class="spec-row">
            <div class="spec-label" data-i18n="nameLabel">الاسم</div>
            <div class="spec-value">{{ product.name }}</div>
          </div>

          <div class="spec-row">
            <div class="spec-label" data-i18n="priceLabel">السعر</div>
            <div class="spec-value">{{ product.price | egp }}</div>
          </div>

          {% if product.category_name %}
          <div class="spec-row">
            <div class="spec-label" data-i18n="categoryLabel">الكاتيجوري</div>
            <div class="spec-value">{{ product.category_name }}</div>
          </div>
          {% endif %}

          <div class="spec-row">
            <div class="spec-label" data-i18n="statusLabel">الحالة</div>
            <div class="spec-value" data-i18n="available">متاح</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.name | jsonLdSafe }}",
  "description": "{{ (product.description_ar or product.description or product.name) | seoDesc(product.name) | jsonLdSafe }}",
  "image": [
    "{{ settings.siteUrl }}{{ product.main_image or '/assets/images/products/default-product.jpeg' }}"
  ],
  "brand": {
    "@type": "Brand",
    "name": "{{ settings.brand }}"
  },
  "category": "{{ product.category_name or product.category or 'Outdoor Furniture' }}",
  "offers": {
    "@type": "Offer",
    "url": "{{ settings.siteUrl }}/products/{{ product.slug }}/",
    "priceCurrency": "EGP",
    "price": "{{ product.price or 0 }}",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition"
  }
}
</script>
