---
layout: layouts/base.njk
---
title: "{{ product.name }} | Nestica"
description: "{{ product.description_ar }}"
<section class="py-5 product-details-page">
  <div class="container">
    <div class="row g-5 align-items-start">
      <div class="col-lg-6">
        <div class="rounded-4 overflow-hidden shadow-sm mb-3 product-main-wrap">
          <img id="mainProductImage" src="{{ product.main_image or '/assets/images/products/default-product.jpeg' }}" class="img-fluid w-100" alt="{{ product.name }}" onerror="this.onerror=null;this.src='/assets/images/products/default-product.jpeg';">
        </div>
        {% if product.gallery and product.gallery.length > 1 %}
        <div class="d-flex flex-wrap gap-2 product-thumbs">
          {% for img in product.gallery %}
          <img src="{{ img }}" class="border rounded-3" onclick="changeMainImage('{{ img }}')" alt="{{ product.name }}" onerror="this.onerror=null;this.src='/assets/images/products/default-product.jpeg';">
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <div class="col-lg-6">
        {% if product.category_name %}<div class="text-muted mb-2">{{ product.category_name }}</div>{% endif %}
        <h1 class="fw-bold mb-3">{{ product.name }}</h1>
        <div class="fs-3 fw-bold mb-4">{{ product.price | egp }}</div>

        <div class="mb-4">
          <label class="form-label fw-semibold" data-i18n="quantity">الكمية</label>
          <input type="number" id="quantity" value="1" min="1" class="form-control">
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold" data-i18n="requestType">نوع الطلب</label>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="requestType" id="requestTypeSame" value="same" checked onchange="toggleNotes()">
            <label class="form-check-label" for="requestTypeSame" data-i18n="sameAsProduct">نفس المنتج</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="requestType" id="requestTypeCustom" value="custom" onchange="toggleNotes()">
            <label class="form-check-label" for="requestTypeCustom" data-i18n="customModification">تعديل خاص</label>
          </div>
        </div>

        <div class="mb-3" id="notesBox" style="display:none;">
          <label class="form-label fw-semibold" data-i18n="writeRequest">اكتب طلبك</label>
          <textarea id="notes" class="form-control" rows="4" placeholder="اكتب اللون، المقاس، أو أي تعديل مطلوب"></textarea>
        </div>

        <button class="btn btn-dark rounded-pill px-4 w-100" onclick='addProductDetailsToCart({ id: "{{ product.id }}", name: "{{ product.name }}", price: {{ product.price or 0 }}, image: "{{ product.main_image }}", slug: "{{ product.slug }}" })' data-i18n="addToCart">أضف للسلة</button>
      </div>
    </div>

    <section class="product-description-section mt-5">
      <div class="product-desc-card">
        <div class="row g-4">
          <div class="col-lg-6">
            <div class="desc-block">
              <h3 class="desc-title" data-i18n="description">الوصف</h3>
              <hr class="desc-divider">
              <div class="desc-content formatted-description">{{ product.description | replace('\n', '<br>') | safe }}</div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="specs-block">
              <h3 class="desc-title" data-i18n="specifications">المواصفات</h3>
              <hr class="desc-divider">
              <div class="specs-table">
                <div class="spec-row"><div class="spec-label" data-i18n="nameLabel">الاسم</div><div class="spec-value">{{ product.name }}</div></div>
                <div class="spec-row"><div class="spec-label" data-i18n="priceLabel">السعر</div><div class="spec-value">{{ product.price | egp }}</div></div>
                {% if product.category_name %}<div class="spec-row"><div class="spec-label" data-i18n="categoryLabel">الكاتيجوري</div><div class="spec-value">{{ product.category_name }}</div></div>{% endif %}
                <div class="spec-row"><div class="spec-label" data-i18n="statusLabel">الحالة</div><div class="spec-value" data-i18n="available">متاح</div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</section>
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "{{ product.name }}",
  "image": "{{ product.main_image }}",
  "description": "{{ product.description_ar | escape }}",
  "brand": {
    "@type": "Brand",
    "name": "Nestica"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "EGP",
    "price": "{{ product.price }}",
    "availability": "https://schema.org/InStock"
  }
}
</script>