---
layout: layouts/base.njk
title: Cart
permalink: /cart/
---

<section class="container my-5 cart-page">
  <div class="text-center mb-5">
    <h1 class="fw-bold" data-i18n="cartTitle">سلة الطلبات</h1>
    <p class="text-muted" data-i18n="cartSubtitle">راجع المنتجات وأرسل الطلب على واتساب.</p>
  </div>

  <div class="row g-4 align-items-start">
    <div class="col-lg-8">
      <div id="emptyCart" class="text-center py-5 d-none">
        <h4 class="fw-bold" data-i18n="emptyCart">السلة فارغة</h4>
        <p class="text-muted">ابدأ بتصفح المنتجات وأضف ما يناسبك.</p>
        <a href="/products/" class="btn btn-dark rounded-pill px-4" data-i18n="shopNow">تسوق الآن</a>
      </div>

      <div id="cartItems"></div>
    </div>

    <div class="col-lg-4">
      <div class="cart-summary card border-0 shadow-sm rounded-4 p-4 sticky-lg-top" style="top: 90px;">
        <h4 class="fw-bold mb-3" data-i18n="orderData">بيانات الطلب</h4>

        <div class="mb-3">
          <label class="form-label fw-semibold"><span data-i18n="customerName">الاسم</span> <span class="text-danger">*</span></label>
          <input id="customerName" class="form-control" type="text" placeholder="اكتب اسمك" required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold"><span data-i18n="customerPhone">رقم الهاتف</span> <span class="text-danger">*</span></label>
          <input id="customerPhone" class="form-control" type="tel" placeholder="01xxxxxxxxx" required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold"><span data-i18n="customerAddress">العنوان</span> <span class="text-danger">*</span></label>
          <textarea id="customerAddress" class="form-control" rows="3" placeholder="اكتب العنوان أو المنطقة" required></textarea>
        </div>

        <hr>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <span class="fw-semibold" data-i18n="total">الإجمالي</span>
          <strong id="cartTotal">0 EGP</strong>
        </div>

        <button class="btn btn-success w-100 rounded-pill py-2 fw-bold" onclick="sendCartToWhatsApp('{{ settings.whatsapp }}')">
          <i class="bi bi-whatsapp me-1"></i>
          <span data-i18n="sendWhatsapp">إرسال على واتساب</span>
        </button>

        <button class="btn btn-outline-danger w-100 rounded-pill mt-2" onclick="clearCart()" data-i18n="clearCart">تفريغ السلة</button>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    renderCart();
    updateCartCount();
  });
</script>
